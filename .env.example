# ──────────────────────────────────────────────────────
# ReUseITESO — Variables de entorno (local dev)
# Copia este archivo como .env en la raíz del proyecto:
#   cp .env.example .env
# ──────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────
SECRET_KEY=django-insecure-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL (deben coincidir con docker-compose) ──
DB_NAME=reuse_iteso_dev
DB_USER=reuse_dev
DB_PASSWORD=local_dev_password
DB_HOST=localhost
DB_PORT=5432

# ── CORS ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── AWS ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=aws_access_key
AWS_SECRET_ACCESS_KEY=aws_secret
AWS_STORAGE_BUCKET_NAME=iteso-reuse-product-images
AWS_S3_REGION_NAME=us-east-2