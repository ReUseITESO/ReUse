# =============================================================
# ReUse ITESO — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env al repositorio.
# =============================================================

# ── Django ────────────────────────────────────────────────────
# Genera una clave segura con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-key-change-in-production
DEBUG=True
# En producción: dominio real, e.g. "reuse.iteso.mx,www.reuse.iteso.mx"
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend

# ── Base de datos ─────────────────────────────────────────────
DB_NAME=reuse_iteso_dev
DB_USER=reuse_dev
DB_PASSWORD=local_dev_password
DB_HOST=db
DB_PORT=5432

# ── CORS ──────────────────────────────────────────────────────
# En producción: URL real del frontend, e.g. "https://reuse.iteso.mx"
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── URLs base ─────────────────────────────────────────────────
# En producción: URL real del frontend
FRONTEND_BASE_URL=http://localhost:3000
# En producción: URL real del backend
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ── Email / SendGrid ──────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=reuseiteso@outlook.com
EMAIL_VERIFICATION_EXPIRES_MINUTES=30

# ── Microsoft OAuth ───────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
# En producción: URL real del frontend + ruta de callback
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback
