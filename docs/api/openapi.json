openapi: 3.0.3
info:
  title: ReUseITESO API
  version: 1.0.0
  description: 'REST API for ReUseITESO — a second-hand marketplace platform for ITESO
    students. Modules: <br> Core (auth, users), <br>Marketplace (products, categories,
    transactions), <br>Gamification (points, badges, rankings).<br>'
  contact:
    name: ReUseITESO Team
paths:
  /api/auth/account/deactivate/:
    post:
      operationId: auth_account_deactivate_create
      description: |-
        POST /api/auth/account/deactivate/
        Desactiva lógicamente la cuenta del usuario autenticado.
      tags:
      - auth
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/auth/account/reactivate/confirm/:
    get:
      operationId: auth_account_reactivate_confirm_retrieve
      description: |-
        GET /api/auth/account/reactivate/confirm/?token=...
        Confirma el token y reactiva la cuenta.
      tags:
      - auth
      security:
      - jwtAuth: []
      - BearerAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/auth/account/reactivate/send/:
    post:
      operationId: auth_account_reactivate_send_create
      description: |-
        POST /api/auth/account/reactivate/send/
        Envía email con enlace de reactivación. Respuesta genérica para no filtrar existencia.
      tags:
      - auth
      security:
      - jwtAuth: []
      - BearerAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/auth/dashboard/:
    get:
      operationId: auth_dashboard_retrieve
      description: GET /api/auth/dashboard/ — aggregated home dashboard data.
      tags:
      - auth
      security:
      - jwtAuth: []
      - BearerAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/auth/email-verification/confirm/:
    get:
      operationId: auth_email_verification_confirm_retrieve
      description: |-
        GET /api/auth/email-verification/confirm/?token=...
        Verifica token one-time. Si es válido:
        - marca usuario verificado y activo
        - devuelve JWT tokens (login automático)
      tags:
      - auth
      security:
      - jwtAuth: []
      - BearerAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/auth/email-verification/send/:
    post:
      operationId: auth_email_verification_send_create
      description: |-
        POST /api/auth/email-verification/send/
        Dispara (re)envío de correo de verificación.
        Respuesta genérica para no filtrar si el email existe.
      tags:
      - auth
      security:
      - jwtAuth: []
      - BearerAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/auth/microsoft/:
    get:
