components:
  schemas:
    ActionEnum:
      enum:
      - publish_item
      - complete_donation
      - complete_sale
      - complete_exchange
      - receive_positive_review
      type: string
      description: |-
        * `publish_item` - Publish item
        * `complete_donation` - Complete donation
        * `complete_sale` - Complete sale
        * `complete_exchange` - Complete exchange
        * `receive_positive_review` - Receive positive review
    AwardPointsRequest:
      type: object
      properties:
        user_id:
          type: integer
        action:
          $ref: '#/components/schemas/ActionEnum'
        reference_id:
          type: integer
      required:
      - action
    Category:
      type: object
      description: Serializer for product categories.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 100
        icon:
          type: string
          nullable: true
          maxLength: 500
      required:
      - id
      - name
    Challenge:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        title:
          type: string
          maxLength: 120
        description:
          type: string
        challenge_type:
          $ref: '#/components/schemas/ChallengeTypeEnum'
        goal:
          type: integer
          maximum: 2147483647
          minimum: 1
        bonus_points:
          type: integer
          maximum: 2147483647
          minimum: 0
        start_date:
          type: string
          format: date-time
        end_date:
          type: string
          format: date-time
        joined:
          type: string
          readOnly: true
      required:
      - challenge_type
      - description
      - end_date
      - goal
      - id
      - joined
      - start_date
      - title
    ChallengeTypeEnum:
      enum:
      - donation
      - exchange
      - sale
      - publish
      - review
      type: string
      description: |-
        * `donation` - Donation
        * `exchange` - Exchange
        * `sale` - Sale
        * `publish` - Publish
        * `review` - Review
    Comment:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
