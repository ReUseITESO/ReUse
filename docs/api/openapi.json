  /api/marketplace/products/:
    get:
      operationId: marketplace_products_list
      description: Returns a paginated list of products with status **disponible**.
        <br>Supports filtering by category, condition, and transaction type via query
        params. <br>Results can be searched by **title**, **description**, or **category**
        name,and ordered by created_at, price, or title. <br><br>Use `?seller=me`
        to list all products owned by the authenticated user (any status). Requires
        JWT authentication. <br><br>Use `?community={id}` to filter by community (requires
        membership). Use `?scope=communities` to list all items from your joined communities.
      summary: List available products
      parameters:
      - in: query
        name: category
        schema:
          type: integer
        description: Filter by category ID.
      - in: query
        name: community
        schema:
          type: integer
        description: Filter by community ID (requires membership to view community
          items).
      - in: query
        name: condition
        schema:
          type: string
          enum:
          - buen_estado
          - como_nuevo
          - nuevo
          - usado
        description: 'Filter by product condition. Options: `nuevo`, `como_nuevo`,
          `buen_estado`, `usado`.'
      - in: query
        name: ordering
        schema:
          type: string
        description: 'Order results. Options: `created_at`, `-created_at`, `price`,
          `-price`, `title`, `-title`, `-likes_count`.'
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: scope
        schema:
          type: string
          enum:
          - communities
        description: Use `communities` to show all items from your joined communities.
      - in: query
        name: search
        schema:
          type: string
        description: Search products by title, description, or category name.
      - in: query
        name: seller
        schema:
          type: string
          enum:
          - me
        description: Use `me` to list the authenticated user's own products (all statuses).
      - in: query
        name: transaction_type
        schema:
          type: string
          enum:
          - donation
          - sale
          - swap
        description: 'Filter by transaction type. Options: `donation`, `sale`, `swap`.'
      tags:
      - Marketplace > Products
      security:
      - jwtAuth: []
      - BearerAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedProductListList'
          description: ''
    post:
      operationId: marketplace_products_create
      description: Creates a new product listing for the authenticated user. <br>Requires
        JWT authentication. <br>Optionally set `community_id` to publish to a specific
        community (must be a member).
      summary: Publish a product
      tags:
      - Marketplace > Products
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ProductCreateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ProductCreateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ProductCreateRequest'
        required: true
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductCreate'
          description: ''
